# Banco de dados (local: PostgreSQL na sua máquina)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/keepr

# Secrets — TROQUE em produção
SECRET_KEY=dev-secret-key-troque-em-producao
JWT_SECRET_KEY=jwt-dev-secret-troque-em-producao

# OCR — Gemini Vision (Google AI Studio)
# Gere a chave em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Ambiente
FLASK_ENV=development

# --- Email (opcional — notificações de vencimento via Resend) ---
# Sem RESEND_API_KEY o app funciona normalmente, apenas não envia email.
# RESEND_API_KEY=
# EMAIL_FROM=Keepr <onboarding@resend.dev>
# EMAIL_TO_OVERRIDE=
